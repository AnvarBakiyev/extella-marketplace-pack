{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://extella.ai/schemas/client-release-manifest-v1.json",
  "title": "Extella client release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseId",
    "version",
    "status",
    "supportedPlatforms",
    "distribution",
    "dependencies",
    "accountResources",
    "lifecycle",
    "services",
    "telemetry",
    "sourceRepositories",
    "artifacts",
    "capabilities",
    "installers",
    "verification"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "releaseId": {"const": "extella-client"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"},
    "status": {"enum": ["candidate", "released", "withdrawn"]},
    "supportedPlatforms": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {"enum": ["macos-x86_64", "macos-arm64", "windows11-x86_64"]}
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "fileName", "sha256", "bytes", "fileCount"],
      "properties": {
        "status": {"enum": ["pending", "candidate", "released"]},
        "fileName": {"type": "string", "minLength": 1},
        "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "bytes": {"type": ["integer", "null"], "minimum": 1},
        "fileCount": {"type": ["integer", "null"], "minimum": 1}
      }
    },
    "dependencies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "requiredForCore", "minimumVersion", "resolver"],
        "properties": {
          "name": {"type": "string"},
          "requiredForCore": {"type": "boolean"},
          "minimumVersion": {"type": ["string", "null"]},
          "resolver": {"enum": ["ensure_tool", "pinned_native_bootstrap"]}
        }
      }
    },
    "accountResources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "agents", "experts", "kv"],
      "properties": {
        "scope": {"const": "current_account"},
        "agents": {
          "type": "object",
          "additionalProperties": false,
          "required": ["count", "strategy", "provider", "model"],
          "properties": {
            "count": {"const": 1},
            "strategy": {"const": "token_associated"},
            "provider": {"const": "alibaba"},
            "model": {"type": "string"}
          }
        },
        "experts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inventory", "installClass", "smokeContract"],
          "properties": {
            "inventory": {"type": "string"},
            "installClass": {"const": "bundled"},
            "smokeContract": {"const": "extella-install-smoke-v1"}
          }
        },
        "kv": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["install", "start", "stop", "restart", "health", "uninstall"],
      "properties": {
        "install": {"type": "string"},
        "start": {"type": "string"},
        "stop": {"type": "string"},
        "restart": {"type": "string"},
        "health": {"type": "string"},
        "uninstall": {"type": "string"}
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "owner", "port", "autostart"],
        "properties": {
          "id": {"type": "string"},
          "owner": {"type": "string"},
          "port": {"type": "integer", "minimum": 1024, "maximum": 65535},
          "autostart": {"enum": ["native", "activity_center"]}
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "transport", "storage"],
      "properties": {
        "schema": {"type": "string"},
        "transport": {"const": "disabled"},
        "storage": {"type": "string"}
      }
    },
    "sourceRepositories": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "revision"],
        "properties": {
          "id": {"type": "string"},
          "url": {"type": "string"},
          "revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "sha256", "bytes", "required", "platforms"],
        "properties": {
          "id": {"type": "string"},
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 1},
          "required": {"type": "boolean"},
          "platforms": {
            "type": "array",
            "minItems": 1,
            "items": {"enum": ["macos-x86_64", "macos-arm64", "windows11-x86_64"]}
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "classification", "manifest", "required"],
        "properties": {
          "id": {"type": "string"},
          "classification": {"enum": ["bundled", "supported_on_demand", "third_party_unverified"]},
          "manifest": {"type": "string"},
          "required": {"type": "boolean"}
        }
      }
    },
    "installers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["macos", "windows11"],
      "properties": {
        "macos": {"type": "string"},
        "windows11": {"type": "string"}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gateVersion", "matrix"],
      "properties": {
        "gateVersion": {"type": "integer", "minimum": 1},
        "matrix": {
          "type": "object",
          "additionalProperties": false,
          "required": ["macos-x86_64", "macos-arm64", "windows11-x86_64"],
          "properties": {
            "macos-x86_64": {"enum": ["pending", "passed", "failed"]},
            "macos-arm64": {"enum": ["pending", "passed", "failed"]},
            "windows11-x86_64": {"enum": ["pending", "passed", "failed"]}
          }
        }
      }
    }
  }
}
