{
  "schemaVersion": 1,
  "id": "extella_contract_agent",
  "name": "Extella Contract Agent",
  "description": "Human-in-the-loop contract review and negotiation workflow.",
  "version": "1.1.0-rc.1",
  "classification": "supported_on_demand",
  "source": {"type": "bundled", "locator": "automations/ui/extella_contract_agent", "revision": "release"},
  "supportedPlatforms": ["macos-x86_64", "macos-arm64", "windows11-x86_64"],
  "install": {
    "strategy": "on_demand",
    "entrypoints": {"macos": "installer/plugin_lifecycle.py", "windows11": "installer/plugin_lifecycle.py"},
    "idempotent": true,
    "transactional": true,
    "mutablePaths": ["${EXTELLA_DATA}/plugins/extella_contract_agent"]
  },
  "runtime": {
    "kind": "local_service",
    "owner": "extella_contract_agent",
    "command": ["${PYTHON}", "${EXTELLA_DATA}/plugins/extella_contract_agent/server.py"],
    "port": {"mode": "fixed", "preferred": 8767, "bind": "127.0.0.1"},
    "health": {"type": "http", "path": "/x/health", "timeoutSeconds": 30},
    "pid": {"strategy": "service_manager", "path": null},
    "autostart": {"macos": "launchagent", "windows11": "scheduled_task"}
  },
  "ui": {"type": "local_server", "entrypoint": "/onboarding.html", "runtimeId": "extella_contract_agent", "smokePath": "/x/health"},
  "artifacts": {
    "installRoot": "${EXTELLA_DATA}/plugins/extella_contract_agent",
    "registryFile": "${EXTELLA_DATA}/plugins/_registry/extella_contract_agent.json",
    "files": ["index.html", "onboarding.html", "server.py"]
  },
  "experts": {
    "required": ["p2d4_evaluate_contract_batch", "p2d4_generate_document_package", "p2d4_run_pipeline", "p2d5_negotiate", "lp_notify", "lp_email_send", "lp_wa_state", "lp_wa_send", "lp_assistant"],
    "smoke": ["lp_install_smoke"]
  },
  "secrets": [
    {"key": "notification_credentials", "source": "encrypted_vault", "required": false}
  ],
  "uninstall": {"entrypoint": "installer/plugin_lifecycle.py", "preserves": ["contracts", "review outputs", "encrypted credentials"]},
  "migration": {"strategy": "replace_preserve_data", "fromVersions": ["1.0.x"]},
  "releaseState": {"advertised": false, "verification": "pending"}
}
