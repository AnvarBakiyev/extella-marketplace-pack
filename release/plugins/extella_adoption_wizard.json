{
  "schemaVersion": 1,
  "id": "extella_adoption_wizard",
  "name": "Extella Adoption Wizard",
  "description": "Local Wizard/Composer runtime backed by per-account Extella experts.",
  "version": "5.0.0-rc.1",
  "classification": "supported_on_demand",
  "source": {
    "type": "repository",
    "locator": "https://github.com/AnvarBakiyev/extella-adoption-wizard.git",
    "revision": "8b546d96ab9246f5e93d4a7e39d50b573a5504cd"
  },
  "supportedPlatforms": ["macos-x86_64", "macos-arm64", "windows11-x86_64"],
  "install": {
    "strategy": "on_demand",
    "entrypoints": {"macos": "installer/plugin_lifecycle.py", "windows11": "installer/plugin_lifecycle.py"},
    "idempotent": true,
    "transactional": true,
    "mutablePaths": ["${EXTELLA_DATA}/wizard/app", "${EXTELLA_DATA}/wizard/catalog", "${EXTELLA_DATA}/wizard/sessions"]
  },
  "runtime": {
    "kind": "local_service",
    "owner": "extella_adoption_wizard",
    "command": ["${PYTHON}", "${EXTELLA_DATA}/wizard/app/server.py"],
    "port": {"mode": "fixed", "preferred": 8765, "bind": "127.0.0.1"},
    "health": {"type": "http", "path": "/x/health", "timeoutSeconds": 60},
    "pid": {"strategy": "service_manager", "path": null},
    "autostart": {"macos": "launchagent", "windows11": "scheduled_task"}
  },
  "ui": {"type": "local_server", "entrypoint": "/wizard.html", "runtimeId": "extella_adoption_wizard", "smokePath": "/x/health"},
  "artifacts": {
    "installRoot": "${EXTELLA_DATA}/wizard/app",
    "registryFile": "${EXTELLA_DATA}/plugins/_registry/extella_adoption_wizard.json",
    "files": [
      "catalog.json",
      "server.py",
      "wizard.html",
      "workspace/VERSION",
      "workspace/index.html",
      "workspace/server.py",
      "workspace/workspace_autopilot.py",
      "workspace/workspace_refresh.py",
      "wz_agentic.py",
      "wz_build.py",
      "wz_llm.py",
      "wz_platform.py",
      "wz_process.py"
    ]
  },
  "experts": {
    "required": [
      "cspl_report_dsl",
      "fmt_report_docx",
      "fmt_report_pdf",
      "fmt_report_pptx",
      "fmt_report_xlsx",
      "wz_agent_runlog",
      "wz_ask_agent",
      "wz_auto_compose",
      "wz_build_plan",
      "wz_build_runner",
      "wz_capability_install",
      "wz_capability_search",
      "wz_capability_uninstall",
      "wz_connector_email",
      "wz_connector_slack",
      "wz_connector_sms",
      "wz_connector_telegram",
      "wz_connector_whatsapp",
      "wz_data_reality_check",
      "wz_deploy_agent",
      "wz_digest_pipeline",
      "wz_first_win_demo",
      "wz_flow_run",
      "wz_generate_blueprint",
      "wz_install_autostart",
      "wz_onboard_device",
      "wz_open_wizard",
      "wz_ping",
      "wz_project_spec",
      "wz_publish_pack",
      "wz_registry_rebuild",
      "wz_scheduler_tick",
      "wz_seed_library",
      "wz_session",
      "wz_session_prune",
      "wz_source_1c_file",
      "wz_source_1c_winrm",
      "wz_source_amocrm",
      "wz_source_bitrix24",
      "wz_source_gen_run",
      "wz_source_gsheets",
      "wz_source_mysql",
      "wz_source_postgres",
      "wz_target_passport",
      "wz_vault_provision",
      "wz_wizard_serve",
      "wz_wizard_stop",
      "wz_workspace"
    ],
    "smoke": ["wz_ping"]
  },
  "secrets": [
    {"key": "extella_session", "source": "extella_session", "required": true},
    {"key": "vault_pin", "source": "user_prompt", "required": false}
  ],
  "uninstall": {"entrypoint": "installer/plugin_lifecycle.py", "preserves": ["sessions", "reports", "encrypted vault"]},
  "migration": {"strategy": "replace_preserve_data", "fromVersions": ["1.x", "4.x"]},
  "releaseState": {"advertised": false, "verification": "pending"}
}
